# ---- Provider selection ----
# Supported values: nvidia (default), openai, gemini
PROVIDER=nvidia

# ---- Nvidia NIM (default provider) ----
NVIDIA_API_KEY=nvapi-...
# Optional: override to point at a self-hosted NIM instance
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Optional: override the default NIM model
# MODEL_NAME=meta/llama-3.1-70b-instruct

# ---- OpenAI (alternative provider) ----
# Set PROVIDER=openai and supply this key to use OpenAI instead
# OPENAI_API_KEY=sk-...
# MODEL_NAME=gpt-4o-mini

# ---- Google Gemini (alternative provider) ----
# Set PROVIDER=gemini and supply this key to use Gemini instead
# GOOGLE_API_KEY=AIza...
# MODEL_NAME=gemini-1.5-flash

# ---- LangSmith (optional tracing) ----
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=my_enterprise_agent
